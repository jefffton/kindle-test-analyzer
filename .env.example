# Copy this file to .env and fill in your values

# Option A: Direct Anthropic API key (get one from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: AWS Bedrock (if using Bedrock instead of direct API)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
# AWS_DEFAULT_REGION=us-east-1
